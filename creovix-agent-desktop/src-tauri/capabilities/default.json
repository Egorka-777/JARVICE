{
  "$schema": "https://schema.tauri.app/schema/2/capability.json",
  "identifier": "default",
  "description": "Default capabilities for J.A.R.V.I.C.E",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "node-runner",
          "cmd": "node",
          "args": true
        },
        {
          "name": "binaries/node",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "node-runner",
          "cmd": "node",
          "args": true
        },
        {
          "name": "binaries/node",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
