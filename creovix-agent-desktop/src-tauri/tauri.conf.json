{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Creovix Agent Desktop",
  "version": "0.1.0",
  "identifier": "com.creovix.agent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Джарвис / Creovix Agent",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../scripts/runner.js": "scripts/runner.js",
      "../scripts/seed-bing-scenario.js": "scripts/seed-bing-scenario.js"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
