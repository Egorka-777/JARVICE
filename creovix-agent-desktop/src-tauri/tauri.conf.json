{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "J.A.R.V.I.C.E",
  "version": "0.1.2",
  "identifier": "com.creovix.agent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run prepare-runtime",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "J.A.R.V.I.C.E",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/node"],
    "resources": {
      "runtime-payload/": "runtime/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
