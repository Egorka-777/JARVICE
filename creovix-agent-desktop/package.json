    "@tauri-apps/plugin-sql": "^2.2.0",
    "better-sqlite3": "^11.7.0",
    "csv-parse": "^5.6.0",
    "csv-parser": "^3.0.0",
    "csv-stringify": "^6.5.2",
    "playwright": "^1.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tauri-apps/cli": "^2.2.0",
