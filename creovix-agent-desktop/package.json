  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare-runtime": "node scripts/prepare-runtime.mjs",
    "lint": "eslint -c .eslintrc.cjs src database --ext .ts,.tsx",
